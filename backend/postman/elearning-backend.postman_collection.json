{
  "info": {
    "_postman_id": "1e42f0de-afca-4c4f-a3cd-bef97a7b0d39",
    "name": "E-Learning Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) pm.environment.set('studentAccessToken', json.accessToken);",
                  "if (json.refreshToken) pm.environment.set('studentRefreshToken', json.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Teacher",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{teacherEmail}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) pm.environment.set('teacherAccessToken', json.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) pm.environment.set('adminAccessToken', json.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Student Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{studentRefreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) pm.environment.set('studentAccessToken', json.accessToken);",
                  "if (json.refreshToken) pm.environment.set('studentRefreshToken', json.refreshToken);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Audit",
      "item": [
        {
          "name": "Log User Action",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentAccessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/audit/user-action",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"course.view\",\n  \"targetType\": \"course\",\n  \"targetId\": \"course-123\",\n  \"metadata\": {\n    \"source\": \"postman\"\n  }\n}"
            }
          }
        },
        {
          "name": "Log Admin Activity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/audit/admin-activity",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"admin.user.delete\",\n  \"targetType\": \"user\",\n  \"targetId\": \"user-123\",\n  \"metadata\": {\n    \"activityType\": \"admin\"\n  }\n}"
            }
          }
        },
        {
          "name": "Get Audit Logs (Teacher/Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacherAccessToken}}" }],
            "url": "{{baseUrl}}/audit?page=1&limit=20"
          }
        }
      ]
    },
